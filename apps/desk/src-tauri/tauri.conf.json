{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InventorySim",
  "version": "0.1.0",
  "identifier": "com.digitalco.inventorysim",
  "build": {
    "beforeDevCommand": "npm run dev --workspace apps/desk",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --workspace apps/desk",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Inventory Sim",
        "width": 1400,
        "height": 900
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
